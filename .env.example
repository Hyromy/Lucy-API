# ----------------------------------------------------------------------
#     Lucy API - Example environment variables file
#     Copy this file as .env and fill in the required values
# ----------------------------------------------------------------------

# -------------------- 1. General configuration --------------------
# Execution mode (False for development, True for production)
PRODUCTION=False

# Django Secret Key
DJANGO_SECRET_KEY=

# Whether to use SSL for the API (set to True if behind a reverse proxy with SSL termination)
USE_SSL=False

# -------------------- 2. Production settings (required if PRODUCTION=True) --------------------
# Allowed hosts (comma separated)
HOSTS=

# Allowed origins for CORS (comma separated)
CORS_ALLOWED=

# Trusted origins for CSRF (comma separated)
CSRF_TRUSTED=

# Domain for session and CSRF cookies (e.g., .lucy.com)
# Required in production for subdomains to work correctly
SESSION_DOMAIN=

# -------------------- 3. Database configuration (PostgreSQL) --------------------
# These are only used if PRODUCTION=True
PG_DB=
PG_USER=
PG_PASS=
PG_HOST=
PG_PORT=

# -------------------- 4. Redis configuration --------------------
# Format: redis://<HOST>:<PORT>/<DB_NUMBER>
# Docker example: redis://redis:6379/0
# Local development example: redis://localhost:6379/0
REDIS_URL=

# -------------------- 5. OAuth2 configuration --------------------
# ---- Discord ----
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=<HOST>/auth/discord/callback/

# -------------------- 6. Frontend configuration --------------------
# URL of the frontend application (e.g., https://app.lucy.com)
FRONTEND_URL=

# Callback URL for the frontend after authentication (relative to FRONTEND_URL)
FRONTEND_AUTH_CALLBACK_URL=/auth/callback
